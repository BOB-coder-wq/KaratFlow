<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:KaratFlowAvalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
        x:Class="KaratFlowAvalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="💎 Karat Flow - Digital Currency"
        Background="#FFF5F5">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{Binding Greeting}" 
                      FontSize="32" 
                      FontWeight="Bold" 
                      Foreground="#FF6B35"
                      Margin="0,0,0,5"/>
            <TextBlock Text="{Binding Subtitle}" 
                      FontSize="12" 
                      FontStyle="Italic"
                      Foreground="#FF6B35"
                      Margin="5,0,0,10"/>
            <TextBlock Text="{Binding WelcomeMessage}" 
                      FontSize="16" 
                      FontWeight="SemiBold"
                      Foreground="#333333"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Balance Card -->
            <Border Grid.Column="0" 
                    Background="White" 
                    CornerRadius="15" 
                    Padding="20" 
                    Margin="0,0,10,0"
                    BoxShadow="0 2 10 rgba(0,0,0,0.1)">
                <StackPanel>
                    <TextBlock Text="Account Balance" 
                              FontSize="14" 
                              Foreground="Gray" 
                              Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding BalanceDisplay}" 
                              FontSize="36" 
                              FontWeight="Bold" 
                              Foreground="#FF6B35"
                              Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding AccountDisplay}" 
                              FontSize="12" 
                              Foreground="Gray"/>
                </StackPanel>
            </Border>

            <!-- Quick Actions -->
            <Border Grid.Column="1" 
                    Background="White" 
                    CornerRadius="15" 
                    Padding="20" 
                    Margin="10,0,0,0"
                    BoxShadow="0 2 10 rgba(0,0,0,0.1)">
                <StackPanel>
                    <TextBlock Text="Quick Actions" 
                              FontSize="18" 
                              FontWeight="Bold" 
                              Margin="0,0,0,20"/>
                    
                    <Button Content="💸 Send Payment" 
                            Command="{Binding ShowSendPaymentCommand}"
                            Background="#FF6B35" 
                            Foreground="White"
                            Padding="15,10"
                            Margin="0,5"
                            CornerRadius="8"/>
                    
                    <Button Content="💰 Receive Payment" 
                            Command="{Binding ShowReceivePaymentCommand}"
                            Background="#4CAF50" 
                            Foreground="White"
                            Padding="15,10"
                            Margin="0,5"
                            CornerRadius="8"/>
                    
                    <Button Content="📱 Accept NFC Payment" 
                            Command="{Binding ShowNFCPaymentCommand}"
                            Background="#2196F3" 
                            Foreground="White"
                            Padding="15,10"
                            Margin="0,5"
                            CornerRadius="8"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Dynamic Sections -->
        <ScrollViewer Grid.Row="2" Margin="0,20,0,0">
            <StackPanel>
                <!-- Send Payment Section -->
                <Border IsVisible="{Binding IsPaymentSectionVisible}"
                        Background="White" 
                        CornerRadius="15" 
                        Padding="20" 
                        Margin="0,0,0,20"
                        BoxShadow="0 2 10 rgba(0,0,0,0.1)">
                    <StackPanel>
                        <TextBlock Text="Send Karats" 
                                  FontSize="20" 
                                  FontWeight="Bold" 
                                  Margin="0,0,0,20"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Recipient Username:" 
                                      Margin="0,0,0,5"/>
                            <TextBox Grid.Row="0" Grid.Column="1" 
                                     Text="{Binding RecipientUsername}"
                                     Margin="0,0,0,15"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Amount (Karats):" 
                                      Margin="0,0,0,5"/>
                            <NumericUpDown Grid.Row="1" Grid.Column="1" 
                                          Value="{Binding PaymentAmount}"
                                          FormatString="N0"
                                          Margin="0,0,0,15"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Description (Optional):" 
                                      Margin="0,0,0,5"/>
                            <TextBox Grid.Row="2" Grid.Column="1" 
                                     Text="{Binding PaymentDescription}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Height="60"
                                     Margin="0,0,0,15"/>
                            
                            <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                      Text="{Binding PaymentStatus}"
                                      Foreground="#FF6B35"
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,10"/>
                            
                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                                        Orientation="Horizontal" 
                                        HorizontalAlignment="Left">
                                <Button Content="Send Payment" 
                                        Command="{Binding SendPaymentCommand}"
                                        Background="#FF6B35" 
                                        Foreground="White"
                                        Padding="15,8"
                                        Margin="0,0,10,0"
                                        CornerRadius="8"/>
                                <Button Content="Cancel" 
                                        Command="{Binding CancelPaymentCommand}"
                                        Background="Gray" 
                                        Foreground="White"
                                        Padding="15,8"
                                        CornerRadius="8"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- NFC Payment Section -->
                <Border IsVisible="{Binding IsNFCSectionVisible}"
                        Background="White" 
                        CornerRadius="15" 
                        Padding="20" 
                        Margin="0,0,0,20"
                        BoxShadow="0 2 10 rgba(0,0,0,0.1)">
                    <StackPanel>
                        <TextBlock Text="NFC Payment" 
                                  FontSize="20" 
                                  FontWeight="Bold" 
                                  Margin="0,0,0,20"/>
                        
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,20">
                            <ProgressBar IsIndeterminate="{Binding IsNFCProcessing}"
                                         Width="200"
                                         Height="10"
                                         Margin="0,0,20,0"/>
                            <TextBlock Text="{Binding NFCStatus}"
                                      VerticalAlignment="Center"
                                      Foreground="#2196F3"/>
                        </StackPanel>
                        
                        <Button Content="Cancel" 
                                Command="{Binding CancelNFCCommand}"
                                Background="Gray" 
                                Foreground="White"
                                Padding="15,8"
                                HorizontalAlignment="Left"
                                CornerRadius="8"/>
                    </StackPanel>
                </Border>

                <!-- Transaction History -->
                <Border Background="White" 
                        CornerRadius="15" 
                        Padding="20" 
                        BoxShadow="0 2 10 rgba(0,0,0,0.1)">
                    <StackPanel>
                        <TextBlock Text="Recent Transactions" 
                                  FontSize="20" 
                                  FontWeight="Bold" 
                                  Margin="0,0,0,20"/>
                        
                        <ListBox ItemsSource="{Binding Transactions}"
                                 MaxHeight="300"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" 
                                            Margin="0,0,0,5"
                                            Background="#F8F9FA"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock>
                                                <Run Text="{Binding FromUser}" FontWeight="Bold"/>
                                                <Run Text=" → "/>
                                                <Run Text="{Binding ToUser}" FontWeight="Bold"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Amount, StringFormat='{}{0:N0} Karats'}" 
                                                      Foreground="#FF6B35"
                                                      FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Description}" 
                                                      Foreground="Gray"
                                                      FontSize="12"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" 
                                                      Foreground="Gray"
                                                      FontSize="10"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
