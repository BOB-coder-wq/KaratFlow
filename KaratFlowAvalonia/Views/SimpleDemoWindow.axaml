<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="500"
        x:Class="KaratFlowAvalonia.Views.SimpleDemoWindow"
        Title="Karat Flow - Login"
        Width="400" Height="500"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#FF6B35" Offset="0"/>
                <GradientStop Color="#F72B1C" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <!-- Fullscreen Button (Top Right Corner) -->
        <Button x:Name="FullscreenButton"
                Content="⛶"
                Click="FullscreenButton_Click"
                Background="Transparent"
                Foreground="White"
                FontSize="20"
                Padding="10"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,10,0"
                ToolTip.Tip="Toggle Fullscreen"/>
        
        <Border Background="White" CornerRadius="15" Margin="20" Padding="30">
            <StackPanel Spacing="20">
                <!-- Header -->
                <StackPanel HorizontalAlignment="Center" Spacing="10">
                    <TextBlock Text="💎" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Karat Flow" FontSize="24" FontWeight="Bold" 
                              Foreground="#333333" HorizontalAlignment="Center"/>
                    <TextBlock Text="Digital Currency System" FontSize="14" 
                              Foreground="#666666" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Login Form -->
                <StackPanel Spacing="15">
                    <TextBox x:Name="UsernameTextBox" Watermark="Username" 
                             FontSize="14" Padding="10" CornerRadius="8"/>
                    <TextBox x:Name="PasswordTextBox" Watermark="Password" 
                             FontSize="14" Padding="10" CornerRadius="8" PasswordChar="*"/>
                    
                    <Button Content="🔐 Login" 
                            Click="LoginButton_Click"
                            Background="#FF6B35" 
                            Foreground="White"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Padding="0,12"
                            CornerRadius="8"/>
                    
                    <Button Content="📝 Create Account" 
                            Click="CreateAccountButton_Click"
                            Background="#4CAF50" 
                            Foreground="White"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Padding="0,10"
                            CornerRadius="8"/>
                    
                    <Button Content="🔑 Sign in with Google" 
                            Click="GoogleSignInButton_Click"
                            Background="#4285F4" 
                            Foreground="White"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Padding="0,10"
                            CornerRadius="8"/>
                </StackPanel>

                <!-- Demo User Button (Corner) -->
                <Button Content="🎭 Demo User" 
                        Click="DemoUserButton_Click"
                        Background="#9E9E9E" 
                        Foreground="White"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Padding="0,8"
                        CornerRadius="8"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
