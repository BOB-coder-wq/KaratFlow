{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://karatflow-api.vercel.app/api/$1"
    }
  ],
  "env": {
    "MONGODB_URI": "mongodb+srv://karatflow:password123@karatflow.xxxxx.mongodb.net/?retryWrites=true&w=majority",
    "JWT_KEY": "ThisIsASecretKeyForJWTTokenGeneration123456789"
  }
}
